# Application Environment Variables
APP_ENV=development
APP_DEBUG=true

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=api_db
DB_USER=root
DB_PASS=

# JWT Secret Key (Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_that_should_be_long_and_random
JWT_EXPIRATION=3600

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
